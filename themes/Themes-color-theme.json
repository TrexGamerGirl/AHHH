{
  "name": "From Zero",
  "type": "dark",
  "semanticHighlighting": true,

  "colors": {
    "editor.background": "#050505",
    "editor.foreground": "#e0e0e0",

    "activityBar.background": "#0a0a0a",
    "activityBar.foreground": "#ff1e6e",

    "sideBar.background": "#0d0d0d",
    "sideBar.foreground": "#cccccc",

    "statusBar.background": "#0a0a0a",
    "statusBar.foreground": "#ffffff",

    "editorCursor.foreground": "#ff1e6e",
    "editor.selectionBackground": "#ff1e6e40",

    "editorLineNumber.foreground": "#5c5c5c",
    "editorLineNumber.activeForeground": "#ff1e6e"
  },

  "semanticTokenColors": {

    "variable": "#ff4f87",
    "parameter": "#ff7aa8",

    "function": "#ffffff",
    "method": "#ffffff",

    "class": "#ff4f87",
    "type": "#ff4f87",

    "keyword": "#ff1e6e",

    "string": "#ff7aa8",

    "number": "#ff2f6d",

    "operator": "#b3003c",

    "comment": {
      "foreground": "#6e6e6e",
      "fontStyle": "italic"
    }
  },

  "tokenColors": [

    {
      "scope": "comment",
      "settings": {
        "foreground": "#6e6e6e",
        "fontStyle": "italic"
      }
    },

    {
      "scope": "keyword",
      "settings": {
        "foreground": "#ff1e6e"
      }
    },

    {
      "scope": "variable",
      "settings": {
        "foreground": "#ff4f87"
      }
    },

    {
      "scope": "string",
      "settings": {
        "foreground": "#ff7aa8"
      }
    },

    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#ff2f6d"
      }
    },

    {
      "scope": "entity.name.function",
      "settings": {
        "foreground": "#da10a1"
      }
    }

  ]
}